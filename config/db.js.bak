            "is_available TINYINT(1) NOT NULL DEFAULT 1"
        );
        await ensureColumn(
            "users",
            "is_email_verified",
            "is_email_verified TINYINT(1) NOT NULL DEFAULT 0"
        );
        await ensureColumn(
            "users",
            "email_otp_code",
            "email_otp_code VARCHAR(10) DEFAULT NULL"
