async function createSchema() {
    // Users table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS users (
            id INT AUTO_INCREMENT PRIMARY KEY,
            name VARCHAR(255),
            email VARCHAR(255) UNIQUE NOT NULL,
            password VARCHAR(255),
            phone VARCHAR(30),
            role VARCHAR(50) DEFAULT 'customer',
            is_available TINYINT(1) NOT NULL DEFAULT 1,
            delivery_fee_per_order DECIMAL(10,2) NOT NULL DEFAULT 40.00,
            is_email_verified TINYINT(1) NOT NULL DEFAULT 0,
            email_otp_code VARCHAR(10),
            email_otp_expires TIMESTAMP NULL,
            profile_image VARCHAR(1024),
            profile_image_public_id VARCHAR(255),
            addresses JSON DEFAULT ('[]'),
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            KEY idx_email (email),
            KEY idx_role (role)
        )
    `);

    // Addresses table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS addresses (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT NOT NULL,
            label VARCHAR(50),
            door_no VARCHAR(50),
            street VARCHAR(255),
            landmark VARCHAR(255),
            area VARCHAR(100),
            city VARCHAR(100),
            state VARCHAR(100),
            pincode VARCHAR(20),
            latitude DECIMAL(10,8),
            longitude DECIMAL(11,8),
            is_default TINYINT(1) DEFAULT 0,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
            KEY idx_user_id (user_id),
            KEY idx_default (is_default)
        )
    `);

    // Restaurants table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS restaurants (
            id INT AUTO_INCREMENT PRIMARY KEY,
            owner_id INT NOT NULL,
            user_id INT,
            name VARCHAR(255) NOT NULL,
            description TEXT,
            logo LONGTEXT,
            image_url VARCHAR(1024),
            cover_image VARCHAR(1024),
            city VARCHAR(100),
            area VARCHAR(100),
            address TEXT,
            location VARCHAR(255),
            pincode VARCHAR(20),
            landmark VARCHAR(100),
            cuisines JSON DEFAULT ('[]'),
            open_time VARCHAR(10),
            close_time VARCHAR(10),
            days_open JSON DEFAULT ('[]'),
            fssai VARCHAR(100),
            gst VARCHAR(100),
            pan VARCHAR(100),
            email VARCHAR(255),
            phone VARCHAR(30),
            status VARCHAR(50) DEFAULT 'pending',
            is_approved TINYINT(1) NOT NULL DEFAULT 0,
            is_open TINYINT(1) NOT NULL DEFAULT 1,
            is_active TINYINT(1) NOT NULL DEFAULT 1,
            platform_fee_percent DECIMAL(5,2) NOT NULL DEFAULT 18.00,
            payout_notes TEXT,
            rating DECIMAL(3,1) DEFAULT 0,
            total_orders INT DEFAULT 0,
            total_revenue DECIMAL(15,2) DEFAULT 0,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            FOREIGN KEY (owner_id) REFERENCES users(id) ON DELETE CASCADE,
            KEY idx_owner_id (owner_id),
            KEY idx_status (status),
            KEY idx_approved (is_approved)
        )
    `);

    // Restaurant applications table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS restaurant_applications (
            id INT AUTO_INCREMENT PRIMARY KEY,
            owner_id INT NOT NULL,
            owner_name VARCHAR(255),
            email VARCHAR(255),
            phone VARCHAR(50),
            restaurant_name VARCHAR(255),
            address TEXT,
            city VARCHAR(100),
            pincode VARCHAR(20),
            landmark VARCHAR(100),
            cuisines JSON DEFAULT ('[]'),
            open_time VARCHAR(10),
            close_time VARCHAR(10),
            days_open JSON DEFAULT ('[]'),
            fssai VARCHAR(100),
            gst VARCHAR(100),
            pan VARCHAR(100),
            logo LONGTEXT,
            status VARCHAR(50) DEFAULT 'pending',
            restaurant_id INT NULL,
            review_notes TEXT,
            reviewed_by INT NULL,
            reviewed_at TIMESTAMP NULL,
            approved_at TIMESTAMP NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            FOREIGN KEY (owner_id) REFERENCES users(id) ON DELETE CASCADE,
            FOREIGN KEY (reviewed_by) REFERENCES users(id) ON DELETE SET NULL,
            KEY idx_status (status)
        )
    `);

    // Restaurant sessions table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS restaurant_sessions (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT NOT NULL,
            token VARCHAR(255) UNIQUE NOT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
            KEY idx_user_id (user_id),
            KEY idx_token (token)
        )
    `);

    // Menu items table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS menu_items (
            id INT AUTO_INCREMENT PRIMARY KEY,
            restaurant_id INT NOT NULL,
            vendor_id INT,
            name VARCHAR(255) NOT NULL,
            description TEXT,
            price DECIMAL(10,2) NOT NULL DEFAULT 0,
            image VARCHAR(1024),
            category VARCHAR(50) DEFAULT 'Veg',
            meal_type VARCHAR(30) DEFAULT 'Lunch',
            cuisine_type VARCHAR(100),
            food_type VARCHAR(50),
            season VARCHAR(50) DEFAULT 'All',
            rating DECIMAL(3,1) DEFAULT 4.0,
            discount INT DEFAULT 0,
            popularity INT DEFAULT 0,
            preparation_time_mins INT DEFAULT 30,
            available TINYINT(1) NOT NULL DEFAULT 1,
            is_available TINYINT(1) NOT NULL DEFAULT 1,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (restaurant_id) REFERENCES restaurants(id) ON DELETE CASCADE,
            KEY idx_restaurant_id (restaurant_id),
            KEY idx_available (available),
            KEY idx_category (category)
        )
    `);

    // Legacy menu table removed - use menu_items instead
    // await pool.query(`
    //     CREATE TABLE IF NOT EXISTS menu (...)
    // `);

    // Orders table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS orders (
            id INT AUTO_INCREMENT PRIMARY KEY,
            order_number VARCHAR(50) UNIQUE,
            user_id INT NOT NULL,
            restaurant_id INT NOT NULL,
            delivery_partner_id INT,
            address_id INT,
            payment_id VARCHAR(255),
            payment_method VARCHAR(50),
            payment_status VARCHAR(50) DEFAULT 'pending',
            status VARCHAR(50) DEFAULT 'pending',
            subtotal DECIMAL(10,2) DEFAULT 0,
            tax_amount DECIMAL(10,2) DEFAULT 0,
            discount_amount DECIMAL(10,2) DEFAULT 0,
            delivery_fee DECIMAL(10,2) DEFAULT 0,
            total DECIMAL(10,2) DEFAULT 0,
            notes TEXT,
            delivery_notes TEXT,
            phone VARCHAR(30),
            door_no VARCHAR(255),
            street VARCHAR(255),
            area VARCHAR(255),
            city VARCHAR(100),
            state VARCHAR(100),
            pincode VARCHAR(20),
            estimated_delivery_time TIMESTAMP NULL,
            actual_delivery_time TIMESTAMP NULL,
            delivered_at TIMESTAMP NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
            FOREIGN KEY (restaurant_id) REFERENCES restaurants(id) ON DELETE CASCADE,
            FOREIGN KEY (delivery_partner_id) REFERENCES users(id) ON DELETE SET NULL,
            FOREIGN KEY (address_id) REFERENCES addresses(id) ON DELETE SET NULL,
            KEY idx_user_id (user_id),
            KEY idx_status (status),
            KEY idx_restaurant_id (restaurant_id),
            KEY idx_order_number (order_number)
        )
    `);

    // Order items table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS order_items (
            id INT AUTO_INCREMENT PRIMARY KEY,
            order_id INT NOT NULL,
            menu_id INT,
            name VARCHAR(255),
            price DECIMAL(10,2),
            qty INT DEFAULT 1,
            FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
            FOREIGN KEY (menu_id) REFERENCES menu_items(id) ON DELETE SET NULL,
            KEY idx_order_id (order_id)
        )
    `);

    // Order status logs table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS order_status_logs (
            id INT AUTO_INCREMENT PRIMARY KEY,
            order_id INT NOT NULL,
            status VARCHAR(50),
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
            KEY idx_order_id (order_id),
            KEY idx_status (status)
        )
    `);

    // Cart table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS carts (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT NOT NULL,
            menu_id INT,
            name VARCHAR(255),
            price DECIMAL(10,2),
            qty INT DEFAULT 1,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
            FOREIGN KEY (menu_id) REFERENCES menu_items(id) ON DELETE SET NULL,
            KEY idx_user_id (user_id)
        )
    `);

    // Wishlist table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS wishlists (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT NOT NULL,
            menu_id INT,
            name VARCHAR(255),
            price DECIMAL(10,2),
            image VARCHAR(1024),
            description TEXT,
            category VARCHAR(50),
            discount INT DEFAULT 0,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
            FOREIGN KEY (menu_id) REFERENCES menu_items(id) ON DELETE SET NULL,
            KEY idx_user_id (user_id)
        )
    `);

    // Reviews table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS reviews (
            id INT AUTO_INCREMENT PRIMARY KEY,
            order_id INT,
            user_id INT NOT NULL,
            restaurant_id INT NOT NULL,
            menu_item_id INT,
            rating DECIMAL(3,1),
            comment TEXT,
            delivery_rating DECIMAL(3,1),
            delivery_comment TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE SET NULL,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
            FOREIGN KEY (restaurant_id) REFERENCES restaurants(id) ON DELETE CASCADE,
            FOREIGN KEY (menu_item_id) REFERENCES menu_items(id) ON DELETE SET NULL,
            KEY idx_restaurant_id (restaurant_id),
            KEY idx_user_id (user_id),
            KEY idx_menu_item_id (menu_item_id)
        )
    `);

    // Check if menu_item column exists in reviews and add if not
    try {
        await pool.query("SELECT menu_item_id FROM reviews LIMIT 1");
    } catch (e) {
        await pool.query("ALTER TABLE reviews ADD COLUMN menu_item_id INT AFTER restaurant_id");
    }

    // OTP codes table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS otp_codes (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT,
            email VARCHAR(255),
            phone VARCHAR(50),
            otp VARCHAR(20),
            type VARCHAR(50),
            reset_token VARCHAR(255),
            reset_expires TIMESTAMP NULL,
            temp_name VARCHAR(255),
            temp_password VARCHAR(255),
            expires_at TIMESTAMP,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL,
            KEY idx_email (email),
            KEY idx_expires_at (expires_at)
        )
    `);

    // OTP verifications table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS otp_verifications (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT,
            email VARCHAR(255),
            phone VARCHAR(50),
            otp VARCHAR(20),
            type VARCHAR(50),
            is_used TINYINT(1) DEFAULT 0,
            expires_at TIMESTAMP,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL,
            KEY idx_expires_at (expires_at)
        )
    `);

    // OTPs table (legacy)
    await pool.query(`
        CREATE TABLE IF NOT EXISTS otps (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT,
            name VARCHAR(255),
            email VARCHAR(255),
            otp VARCHAR(20),
            password VARCHAR(255),
            reset_token VARCHAR(255),
            reset_expires TIMESTAMP NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            expires_at TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL
        )
    `);

    // Password resets table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS password_resets (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT,
            email VARCHAR(255),
            otp VARCHAR(20),
            reset_token VARCHAR(255),
            reset_expires TIMESTAMP NULL,
            expires_at TIMESTAMP,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL
        )
    `);

    // Delivery assignments table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS delivery_assignments (
            id INT AUTO_INCREMENT PRIMARY KEY,
            order_id INT NOT NULL,
            delivery_partner_id INT NOT NULL,
            status VARCHAR(50) DEFAULT 'assigned',
            assigned_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            accepted_at TIMESTAMP NULL,
            rejected_at TIMESTAMP NULL,
            pickup_time TIMESTAMP NULL,
            delivery_time TIMESTAMP NULL,
            rejection_reason TEXT,
            FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
            FOREIGN KEY (delivery_partner_id) REFERENCES users(id) ON DELETE CASCADE,
            KEY idx_order_id (order_id),
            KEY idx_delivery_partner (delivery_partner_id),
            KEY idx_status (status)
        )
    `);

    // Notifications table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS notifications (
            id INT AUTO_INCREMENT PRIMARY KEY,
            user_id INT NOT NULL,
            title VARCHAR(255),
            message TEXT,
            type VARCHAR(50),
            data JSON,
            is_read TINYINT(1) DEFAULT 0,
            read_at TIMESTAMP NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
            KEY idx_user_id (user_id),
            KEY idx_is_read (is_read)
        )
    `);

    // Admin activity log table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS admin_activity_log (
            id INT AUTO_INCREMENT PRIMARY KEY,
            admin_id INT NOT NULL,
            entity_type VARCHAR(100),
            entity_id INT,
            action VARCHAR(100),
            details JSON,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (admin_id) REFERENCES users(id) ON DELETE SET NULL,
            KEY idx_admin_id (admin_id),
            KEY idx_created_at (created_at)
        )
    `);

    // Vendors table
    await pool.query(`
        CREATE TABLE IF NOT EXISTS vendors (
            vendor_id INT AUTO_INCREMENT PRIMARY KEY,
            restaurant_name VARCHAR(255),
            email VARCHAR(255) UNIQUE,
            phone VARCHAR(30),
            logo_url VARCHAR(1024),
            password_hash VARCHAR(255),
            is_online TINYINT(1) DEFAULT 0,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    `);

    console.log("✓ Database schema initialized successfully");
}

async function initDb() {
    const connectionLimit = Number(process.env.DB_CONNECTION_LIMIT) || 10;
    const connectTimeout = Number(process.env.DB_CONNECT_TIMEOUT) || 20000;
    const config = {
        host: process.env.DB_HOST,
        port: process.env.DB_PORT,
        user: process.env.DB_USER,
        password: process.env.DB_PASS,
        database: process.env.DB_NAME,
        waitForConnections: true,
        connectionLimit,
        connectTimeout,
        enableKeepAlive: true,
        keepAliveInitialDelay: 10000,
    };

    if (process.env.DB_SSL === "true") {
        config.ssl = {
            rejectUnauthorized: process.env.DB_SSL_REJECT !== "false",
        };
        console.log("✓ SSL enabled for DB connection");
    }

    pool = await mysql.createPool(config);
    console.log("✓ Database pool created");

    await createSchema();
    await ensureColumns();

    console.log("✓ Database initialization complete");
}

function getPool() {
    return pool;
}

module.exports = {
    initDb,
    getPool,
    ensureColumns,
};
